{
  "name": "@codexstar/pi-agent-teams",
  "version": "0.4.0",
  "description": "Claude Code agent teams style workflow for Pi.",
  "license": "MIT",
  "author": "codexstar69",
  "private": false,
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codexstar69/pi-agent-teams.git"
  },
  "bugs": "https://github.com/codexstar69/pi-agent-teams/issues",
  "homepage": "https://github.com/codexstar69/pi-agent-teams",
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "lint": "eslint 'extensions/**/*.ts' 'scripts/**/*.ts' 'scripts/**/*.mts'",
    "typecheck": "tsc -p tsconfig.strict.json",
    "check": "npm run typecheck && npm run lint",
    "smoke-test": "tsx scripts/smoke-test.mts",
    "integration-claim-test": "tsx scripts/integration-claim-test.mts",
    "integration-spawn-overrides-test": "tsx scripts/integration-spawn-overrides-test.mts",
    "integration-hooks-remediation-test": "tsx scripts/integration-hooks-remediation-test.mts",
    "integration-heartbeat-lease-scaffold-test": "tsx scripts/integration-heartbeat-lease-scaffold-test.mts",
    "integration-todo-test": "tsx scripts/integration-todo-test.mts",
    "integration-rpc-ready-handshake-test": "tsx scripts/integration-rpc-ready-handshake-test.mts",
    "integration-cleanup-worktree-plan-test": "tsx scripts/integration-cleanup-worktree-plan-test.mts",
    "integration-git-worktree-cleanup-helper-test": "tsx scripts/integration-git-worktree-cleanup-helper-test.mts",
    "integration-git-worktree-cleanup-test": "tsx scripts/integration-git-worktree-cleanup-test.mts",
    "integration-team-doctor-test": "tsx scripts/integration-team-doctor-test.mts",
    "start-team:tmux": "bash scripts/start-tmux-team.sh",
    "start-team:windows": "powershell -ExecutionPolicy Bypass -File scripts/start-team-windows.ps1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@mariozechner/pi-agent-core": "^0.52.8",
    "@mariozechner/pi-ai": "^0.52.8",
    "@mariozechner/pi-coding-agent": "^0.57.1",
    "@mariozechner/pi-tui": "^0.52.8",
    "@sinclair/typebox": "^0.34.48",
    "eslint": "^9.39.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  }
}
